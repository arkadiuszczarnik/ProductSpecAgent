#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
os=$(uname -s | tr '[:upper:]' '[:lower:]')
arch=$(uname -m)

case "$os" in
  linux*) os="linux" ;;
  darwin*) os="darwin" ;;
  *) echo "Unsupported OS: $os" >&2; exit 1 ;;
esac

case "$arch" in
  x86_64|amd64) arch="amd64" ;;
  arm64|aarch64) arch="arm64" ;;
  *) echo "Unsupported architecture: $arch" >&2; exit 1 ;;
esac

target="$os-$arch"
gzip_path="$script_dir/$target/living-sync-reporter.gz"
cache_dir="$script_dir/.cache/$target"
binary_path="$cache_dir/living-sync-reporter"

if [ ! -f "$gzip_path" ]; then
  echo "Missing Living Sync reporter binary: $gzip_path" >&2
  exit 1
fi

if [ ! -x "$binary_path" ] || [ "$gzip_path" -nt "$binary_path" ]; then
  mkdir -p "$cache_dir"
  gzip -dc "$gzip_path" > "$binary_path.tmp"
  mv "$binary_path.tmp" "$binary_path"
  chmod +x "$binary_path"
fi

exec "$binary_path" "$@"
